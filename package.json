{
	"name": "whap",
	"version": "0.2.1",
	"description": "CLI and mock server for testing WhatsApp integration",
	"type": "module",
	"bin": {
		"whap": "./bin.mjs"
	},
	"files": [
		"bin.mjs",
		"src",
		"!src/**/*.test.ts",
		"!src/**/*.test.tsx",
		"!src/**/*.spec.ts",
		"!src/**/*.spec.tsx",
		"templates",
		"schema",
		"whap.json.example"
	],
	"scripts": {
		"whap": "bun run src/index.ts",
		"build": "bun scripts/build-binary.ts",
		"build:all": "bun scripts/build-all.ts",
		"dev:server": "bun run --watch src/server/server.ts",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"test:ui": "vitest --ui",
		"version": "changeset version",
		"release": "bun scripts/build-all.ts && changeset publish"
	},
	"dependencies": {
		"@effect/platform-bun": "4.0.0-beta.59",
		"@hono/node-server": "^1.14.2",
		"@hono/node-ws": "^1.1.7",
		"@types/react": "^18.2.0",
		"@types/uuid": "^10.0.0",
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1",
		"chalk": "^5.3.0",
		"chokidar": "^4.0.3",
		"date-fns": "^3.6.0",
		"dotenv": "^16.5.0",
		"effect": "4.0.0-beta.59",
		"hono": "^4.7.10",
		"ink": "^5.0.1",
		"ky": "^1.7.2",
		"react": "^18.2.0",
		"reconnecting-websocket": "^4.4.0",
		"uuid": "^10.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.31.0",
		"@types/bun": "^1.2.20",
		"@types/json-schema": "^7.0.15",
		"@types/ws": "^8.18.1",
		"@vitest/ui": "^3.2.3",
		"lefthook": "^1.11.13",
		"tsx": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-json-schema": "^0.65.1",
		"vitest": "^3.2.3"
	},
	"packageManager": "bun@1.3.14",
	"engines": {
		"bun": ">=1.3.14"
	}
}
